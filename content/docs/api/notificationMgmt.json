              "application",
              "smoketest",
              "credential",
              "repository",
              "schedule",
              "applicationgroup",
              "clustergroup",
              "imageregistry",
              "backuplocation",
              "snapshot",
              "snapshotinstance",
              "snapshotrestore",
              "notificationrule",
              "notificationchannel"
            ]
          },
          "resourceAction": {
            "type": "array",
