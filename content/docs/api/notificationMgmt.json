              "slack",
              "teams",
              "email",
              "user"
            ]
          }
        }
      },
      "getNotificationRules": {
        "type": "object",
        "allOf": [
          {
            "$ref": "#/components/schemas/notificationRules"
          },
          {
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid"
              },
              "enabled": {
                "type": "boolean",
                "default": true
              },
              "notificationResources": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/notificationResource"
                }
              },
              "notificationTargets": {
                "type": "array",
                "items": {
