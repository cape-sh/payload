{
  "swagger": "2.0",
  "info": {
    "title": "Deployment API",
    "description": "API for CAPE Deployments",
    "version": "1.0.0"
  },
  "host": "www",
  "basePath": "/v2",
  "schemes": [
    "https",
    "http"
  ],
  "paths": {
    "/inventory/deployment": {
      "parameters": [
        {
          "in": "header",
          "name": "organization",
          "type": "string",
          "required": true
        }
      ],
      "post": {
        "parameters": [
          {
            "name": "post_deployments",
            "in": "body",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/deploymentStatus"
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "",
            "schema": {
              "$ref": "#/definitions/errors"
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "422": {
            "description": "Unprocessable Entity",
            "schema": {
              "$ref": "#/definitions/error"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "deploymentStatus": {
      "properties": {
        "deploymentId": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "namespace": {
          "type": "string"
        },
        "objectType": {
          "type": "string"
        },
        "deploymentName": {
          "type": "string"
        },
        "creationDate": {
          "type": "string",
          "format": "date-time"
        },
        "lastUpdate": {
          "type": "string",
          "format": "date-time"
        },
        "deploymentSize": {
          "type": "string"
        },
        "deploymentTime": {
          "type": "string"
        },
        "deploymentCluster": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/cluster"
          }
        }
      }
    },
    "cluster": {
      "properties": {
        "clusterName": {
          "type": "string"
        },
        "clusterId": {
          "type": "string",
          "format": "uuid"
        }
      },
      "required": [
        "clusterName"
      ]
    },
    "error": {
      "properties": {
        "code": {
          "type": "integer"
        },
        "reason": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "status": {
          "type": "string"
        }
      },
      "required": [
        "code",
        "message"
      ]
    },
    "errors": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/error"
      }
    }
  },
  "securityDefinitions": {
    "bearerAuth": {
      "name": "Authorization",
      "in": "header",
      "type": "apiKey",
      "description": "JWT Authorization header"
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ]
}
