          "type": "string"
        },
        "provider": {
          "type": "string",
          "description": "Backup location Cloud provider",
          "enum": [
            "alibabacloud",
            "minio",
            "aws",
            "gcp",
            "huawei",
            "azure",
            "generic_s3"
          ],
          "example": "minio"
        },
        "region": {
          "type": "string"
        },
        "s3": {
          "type": "object",
          "required": [
            "access_key_id",
            "access_secret_key"
          ],
          "properties": {
            "access_key_id": {
              "type": "string",
              "minLength": 3
            },
            "access_secret_key": {
              "type": "string",
              "minLength": 8,
              "maxLength": 40
            },
            "hostname": {
              "type": "string",
              "format": "uri"
            },
            "fqdn": {
              "type": "string",
              "format": "uri",
              "description": "FDQN of minio exposed through ingress"
