  "definitions": {
    "Cluster": {
      "type": "object",
      "required": [
        "description",
        "environment",
        "id",
        "name",
        "provider",
        "autoBuildCluster"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Cluster Identifier"
        },
        "name": {
          "type": "string",
          "description": "Name of Cluster",
          "maxLength": 100
        },
        "description": {
          "type": "string",
          "description": "Description of the cluster"
        },
        "provider": {
          "$ref": "#/definitions/ClusterProvider"
        },
        "environment": {
          "$ref": "#/definitions/ClusterEnvironment"
        },
        "infrastructure": {
          "$ref": "#/definitions/ClusterInfrastructure"
        },
        "createPlaybook": {
          "$ref": "#/definitions/AutomatedClusterPlaybook"
        },
        "autoBuildCluster": {
          "type": "boolean",
          "default": false
        },
        "teardownPlaybook": {
          "$ref": "#/definitions/AutomatedClusterPlaybook"
        },
        "namespace": {
          "type": "string"
        },
        "nodes": {
          "type": "integer",
          "description": "Number of Nodes"
        },
        "region": {
          "type": "string",
          "description": "Geo-location of Cluster"
        },
        "agent": {
          "$ref": "#/definitions/ClusterAgent"
        },
        "groups": {
          "type": "array",
          "description": "List of custom groups a cluster belongs to",
          "items": {
            "$ref": "#/definitions/ClusterCustomGroup"
          }
        },
        "status": {
          "$ref": "#/definitions/Cluster_status"
        },
        "clusterHealth": {
          "$ref": "#/definitions/ClusterHealth"
        },
        "backup": {
          "$ref": "#/definitions/DRBackup"
        },
        "accessGroups": {
          "type": "array",
          "description": "List of access groups with permission to this object",
          "items": {
            "$ref": "#/definitions/accessGroup"
          }
        },
        "created": {
          "type": "string",
          "format": "date-time"
        },
        "updated": {
          "type": "string",
          "format": "date-time"
        },
        "backupLocation": {
          "type": "object",
          "$ref": "#/definitions/backupLocation"
        },
        "backupAgentInstallationFailure": {
          "type": "string"
        }
      }
    },
    "backupLocation": {
      "type": "object",
      "properties": {
        "readOnly": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/backupLocationRef"
          }
        },
        "readWrite": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/backupLocationRef"
          }
        }
      }
    },
    "backupLocationRef": {
      "type": "object",
      "properties": {
        "backupLocationRef": {
          "type": "string"
        }
      }
    },
    "ClusterGroup": {
      "type": "object",
      "required": [
        "description",
        "id",
        "name",
        "namespace",
        "status",
        "type"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Cluster group Identifier"
        },
        "name": {
          "type": "string",
          "description": "Name of Cluster group",
          "maxLength": 100
        },
        "description": {
          "type": "string",
          "description": "Description of cluster group"
        },
        "namespace": {
          "type": "string"
        },
        "status": {
          "type": "boolean"
        },
        "type": {
          "type": "string",
          "enum": [
            "inbuilt",
            "custom"
          ]
        },
        "members": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "accessGroups": {
          "type": "array",
          "description": "List of access groups with permission to this object",
          "items": {
            "$ref": "#/definitions/accessGroup"
          }
        },
        "created": {
          "type": "string",
          "format": "date-time"
        },
        "updated": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "ClusterCustomGroup": {
      "type": "object",
      "required": [
        "id",
        "name"
