{
  "swagger": "2.0",
  "info": {
    "title": "Caepe Reports",
    "description": "Caepe Server Reports API",
    "version": "1.0.0"
  },
  "host": "www",
  "basePath": "/v2",
  "schemes": [
    "https"
  ],
  "paths": {
    "/auditlog": {
      "get": {
        "summary": "Returns the audit trail.",
        "description": "Audit trail retrieval",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "header",
            "name": "organization",
            "type": "string",
            "required": true
          },
          {
            "name": "pageSize",
            "in": "query",
            "type": "integer",
            "default": 10
          },
          {
            "name": "pageNumber",
            "in": "query",
            "type": "integer"
          },
          {
            "name": "resourceType",
            "in": "query",
            "type": "string"
          },
          {
            "name": "resourceName",
            "in": "query",
            "type": "string"
          },
          {
            "name": "user",
            "in": "query",
            "type": "string"
          },
          {
            "name": "action",
            "in": "query",
            "type": "string",
            "enum": [
              "create",
              "update",
              "delete"
            ]
          },
          {
            "name": "fromDateTime",
            "in": "query",
            "type": "string",
            "format": "date-time"
          },
          {
            "name": "toDateTime",
            "in": "query",
            "type": "string",
            "format": "date-time"
          },
          {
            "name": "sort",
            "in": "query",
            "type": "array",
            "collectionFormat": "csv",
            "items": {
              "type": "string",
              "enum": [
                "datetime",
                "user",
                "resourceType",
                "resourceName",
                "action"
              ]
            },
            "description": "Comma seperated values for sorting eg sort=user or sort=user,action"
          },
          {
            "name": "order",
            "in": "query",
            "type": "string",
            "enum": [
              "asc",
              "dsc"
            ],
            "default": "dsc"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/auditLog"
              }
            }
          },
          "400" : {
            "description" : "Errors",
            "schema" : {
              "$ref" : "#/definitions/errors"
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "422": {
            "description": "Unprocessable Entity",
            "schema": {
              "$ref": "#/definitions/error"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "auditLog": {
      "properties": {
        "resourceType": {
          "type": "string"
        },
        "resourceName": {
          "type": "string"
        },
        "action": {
          "type": "string",
          "enum": [
            "create",
            "update",
            "delete"
          ]
        },
        "user": {
          "type": "string"
        },
        "datetime": {
          "type": "string",
          "format": "date-time"
        },
        "metadata": {
          "properties": {
            "totalCount": {
              "type": "integer"
            },
            "pageSize": {
              "type": "integer"
            }
          }
        }
      }
    },
    "errors": {
      "type" : "array",
      "items" : {
        "$ref" : "#/definitions/error"
      },
      "x-omitempty" : true
    },
    "error": {
      "type" : "object",
      "required" : [ "code", "message" ],
      "properties" : {
        "code" : {
          "type" : "integer",
          "format" : "int32"
        },
        "reason" : {
          "type" : "string"
        },
        "message" : {
          "type" : "string"
        },
        "status" : {
          "type" : "string"
        }
      }
    }
  },
  "securityDefinitions": {
    "bearerAuth": {
      "name": "Authorization",
      "in": "header",
      "type": "apiKey",
      "description": "JWT Authorization header"
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ]
}